{
  "name": "redfx-bun",
  "version": "0.1.0",
  "description": "Bun driver adapter for redfx: the send-level port over Bun's native RedisClient, with pub/sub as a Stream.",
  "license": "MIT",
  "author": "Alex Walker",
  "homepage": "https://github.com/al3xanderwalker/redfx",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/al3xanderwalker/redfx.git",
    "directory": "packages/redfx-bun"
  },
  "keywords": [
    "effect",
    "redis",
    "bun",
    "effect-ts"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "effect": "^3.21.0",
    "redfx": "workspace:^"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "effect": "^3.21.3",
    "redfx": "workspace:*",
    "typescript": "^5.9.3"
  }
}
