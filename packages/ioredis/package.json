{
  "name": "@redfx/ioredis",
  "version": "1.0.0",
  "description": "ioredis driver adapter for redfx: the send-level port over ioredis.sendCommand, with pooling and pub/sub.",
  "license": "MIT",
  "author": "Alex Walker",
  "homepage": "https://github.com/al3xanderwalker/redfx",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/al3xanderwalker/redfx.git",
    "directory": "packages/ioredis"
  },
  "keywords": [
    "effect",
    "redis",
    "ioredis",
    "effect-ts"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "effect": "^3.21.0",
    "ioredis": "^5.0.0",
    "@redfx/core": "workspace:^"
  },
  "devDependencies": {
    "effect": "^3.21.3",
    "ioredis": "^5.11.0",
    "@redfx/core": "workspace:*",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
