{
  "name": "redfx-monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Ergonomic Effect-native Redis: typed commands, Schema-typed keys, pub/sub as Stream.",
  "packageManager": "pnpm@11.0.9",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "bun test test/",
    "clean": "rm -rf packages/*/dist packages/*/*.tsbuildinfo"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@redfx/bun": "workspace:*",
    "@redfx/core": "workspace:*",
    "@redfx/ioredis": "workspace:*",
    "@types/bun": "^1.2.0",
    "@types/node": "^25.0.0",
    "effect": "4.0.0-beta.85",
    "fast-check": "^3.23.0",
    "ioredis": "^5.11.0",
    "testcontainers": "^12.0.0",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "effect": "4.0.0-beta.85"
    }
  }
}
